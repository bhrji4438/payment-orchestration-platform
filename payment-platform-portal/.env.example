# =============================================================================
# PAYMENT ORCHESTRATION PLATFORM — Portal Web UI Configuration
# =============================================================================
# Generated automatically using:
#   npm run bootstrap:env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

NODE_ENV=development
PORT=3006

# ─────────────────────────────────────────────
# PORTAL — Next.js Public Variables
# ─────────────────────────────────────────────
# These are baked into the browser bundle at build time.

# URL of the core payment engine API (accessible from the browser client)
NEXT_PUBLIC_CORE_API_URL=http://localhost:3000

# URL of the reporting and analytics service API (accessible from the browser client)
NEXT_PUBLIC_REPORTING_API_URL=http://localhost:3005
