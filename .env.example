# =============================================================================
# PAYMENT ORCHESTRATION PLATFORM — Master Environment Variable Template
# =============================================================================
# Generated automatically using:
#   npm run bootstrap:env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

# ─────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────
# Application environment (development | staging | production)
NODE_ENV=development

# ─────────────────────────────────────────────
# SERVICE PORTS
# ─────────────────────────────────────────────
# HTTP Ports for each running microservice and frontend portal.
# These match the default port configurations.
CORE_PORT=3000
INVOICE_SERVICE_PORT=3001
NOTIFICATION_SERVICE_PORT=3002
AUDIT_SERVICE_PORT=3003
SETTLEMENT_SERVICE_PORT=3004
REPORTING_SERVICE_PORT=3005
PORTAL_PORT=3006

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────
# Database configuration for Docker Compose PostgreSQL container
POSTGRES_DB=payment_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Password@123

# Database Connection (Prisma)
# Local development (connecting from your host machine to Docker container):
DATABASE_URL=postgresql://postgres:Password@123@localhost:5432/payment_platform?schema=public

# Docker Compose internal connection network:
# DATABASE_URL=postgresql://postgres:Password@123@postgres:5432/payment_platform?schema=public

# ─────────────────────────────────────────────
# CACHE (Redis)
# ─────────────────────────────────────────────
# Redis cache connection configuration (Reserved for future use)
# Local development:
REDIS_URL=redis://localhost:6379

# Docker Compose:
# REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────
# KAFKA (Message Broker)
# ─────────────────────────────────────────────
# Kafka connection configuration for events and triggers
# Local development:
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true

# Docker Compose:
# KAFKA_BROKERS=kafka:29092

# ─────────────────────────────────────────────
# ENCRYPTION
# ─────────────────────────────────────────────
# Used by: payment-platform-core (AES-256-GCM gateway credential encryption)
# Base64-encoded 32-byte master key.
# Generate a new key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=cGxhdGZvcm1fbW9kdWxhcl9tb25vbGl0aF9zZWNyZXRfa2V5XzIwMjY=

# ─────────────────────────────────────────────
# WEBHOOK SECRETS
# ─────────────────────────────────────────────
# Signature verification secrets for gateway asynchronous callbacks (webhooks)
WEBHOOK_SECRET_STRIPE=mock_secret
WEBHOOK_SECRET_AUTHORIZE_NET=mock_secret
WEBHOOK_SECRET_NMI=mock_secret
WEBHOOK_SECRET_CARDPOINTE=mock_secret

# ─────────────────────────────────────────────
# SMTP (Email Notifications)
# ─────────────────────────────────────────────
# SMTP Server configuration for notification service (MailHog Sandbox)
# Local development:
SMTP_HOST=localhost
SMTP_PORT=1025

# Docker Compose:
# SMTP_HOST=mailhog
# SMTP_PORT=1025

# ─────────────────────────────────────────────
# OBJECT STORAGE (MinIO / S3)
# ─────────────────────────────────────────────
# S3-compatible file storage configuration for invoices
# Local development:
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=false

# Docker Compose:
# MINIO_ENDPOINT=minio:9000

# ─────────────────────────────────────────────
# PORTAL / CLIENT API PATHS
# ─────────────────────────────────────────────
# Endpoints accessed by Next.js Portal dashboard (Client-side browser bundle)
NEXT_PUBLIC_CORE_API_URL=http://localhost:3000
NEXT_PUBLIC_REPORTING_API_URL=http://localhost:3005

# ─────────────────────────────────────────────
# SDK CONFIGURATION
# ─────────────────────────────────────────────
# Default Core engine URL for the SDK client
PAYMENT_PLATFORM_CORE_URL=http://localhost:3000
