# =============================================================================
# PAYMENT ORCHESTRATION PLATFORM — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
#            The .gitignore already excludes it.
# =============================================================================

# ─────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────

# Application environment: development | staging | production
NODE_ENV=development


# ─────────────────────────────────────────────
# SERVICE PORTS
# Each service reads its own PORT variable.
# These match the defaults in docker-compose.yml.
# ─────────────────────────────────────────────

# Core payment engine
PORT=3000

# Supporting services (set in their own environments / compose definitions)
# INVOICE_SERVICE_PORT=3001
# NOTIFICATION_SERVICE_PORT=3002
# AUDIT_SERVICE_PORT=3003
# SETTLEMENT_SERVICE_PORT=3004
# REPORTING_SERVICE_PORT=3005
# PORTAL_PORT=3006


# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────

# Docker Compose (internal Docker network):
DATABASE_URL=postgresql://postgres:Password@123@postgres:5432/payment_platform?schema=public

# Local development (connecting from host machine):
# DATABASE_URL=postgresql://postgres:Password@123@localhost:5432/payment_platform?schema=public


# ─────────────────────────────────────────────
# CACHE (Redis)
# ─────────────────────────────────────────────

# Docker Compose:
REDIS_URL=redis://redis:6379

# Local development:
# REDIS_URL=redis://localhost:6379


# ─────────────────────────────────────────────
# KAFKA (Message Broker)
# ─────────────────────────────────────────────

# Docker Compose (internal broker address):
KAFKA_BROKERS=kafka:29092

# Local development (external listener):
# KAFKA_BROKERS=localhost:9092

# Set to "false" to disable Kafka publishing (useful for isolated unit testing)
KAFKA_ENABLED=true


# ─────────────────────────────────────────────
# ENCRYPTION
# Used by: payment-platform-core (AES-256-GCM gateway credential encryption)
# Source:  shared/crypto/credential-encryption.ts
# ─────────────────────────────────────────────

# Base64-encoded 32-byte master key.
# Generate a new key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: Rotating this key requires re-encrypting all stored gateway credentials.
ENCRYPTION_MASTER_KEY=cGxhdGZvcm1fbW9kdWxhcl9tb25vbGl0aF9zZWNyZXRfa2V5XzIwMjY=


# ─────────────────────────────────────────────
# SMTP — Email Notifications
# Used by: notification-service
# ─────────────────────────────────────────────

# Docker Compose (MailHog SMTP sink — catches all emails, no real delivery):
SMTP_HOST=mailhog
SMTP_PORT=1025

# Local development:
# SMTP_HOST=localhost
# SMTP_PORT=1025

# Production (e.g., AWS SES, SendGrid, Postmark):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key


# ─────────────────────────────────────────────
# OBJECT STORAGE (MinIO / AWS S3)
# Used by: invoice-service (PDF invoice uploads)
# ─────────────────────────────────────────────

# Docker Compose (MinIO container):
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=false

# Local development:
# MINIO_ENDPOINT=localhost:9000

# Production (AWS S3):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_INVOICE_BUCKET=payment-platform-invoices


# ─────────────────────────────────────────────
# PORTAL — Next.js Public Variables
# Used by: payment-platform-portal
# These are baked into the browser bundle at build time.
# ─────────────────────────────────────────────

# URL of the core payment engine (accessible from the browser)
NEXT_PUBLIC_CORE_API_URL=http://localhost:3000

# URL of the reporting/analytics service
NEXT_PUBLIC_REPORTING_API_URL=http://localhost:3005


# ─────────────────────────────────────────────
# POSTGRES (Docker Compose internal — used by the postgres container itself)
# You do not need to change these unless you change the DATABASE_URL above.
# ─────────────────────────────────────────────

POSTGRES_DB=payment_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Password@123
