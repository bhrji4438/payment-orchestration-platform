# =============================================================================
# PAYMENT ORCHESTRATION PLATFORM — Core Engine Configuration
# =============================================================================
# Generated automatically using:
#   npm run bootstrap:env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

# ─────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────
# Local development connection to local Docker Postgres instance:
DATABASE_URL=postgresql://postgres:Password@123@localhost:5432/payment_platform?schema=public

# ─────────────────────────────────────────────
# CACHE (Redis)
# ─────────────────────────────────────────────
# Local development Redis instance:
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# KAFKA (Message Broker)
# ─────────────────────────────────────────────
# Local development Kafka listener:
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true

# ─────────────────────────────────────────────
# ENCRYPTION
# ─────────────────────────────────────────────
# Base64-encoded 32-byte master key for AES-256-GCM gateway credential encryption.
ENCRYPTION_MASTER_KEY=cGxhdGZvcm1fbW9kdWxhcl9tb25vbGl0aF9zZWNyZXRfa2V5XzIwMjY=

# ─────────────────────────────────────────────
# WEBHOOK SECRETS
# ─────────────────────────────────────────────
# Webhook signature verification keys for gateway callbacks.
WEBHOOK_SECRET_STRIPE=mock_secret
WEBHOOK_SECRET_AUTHORIZE_NET=mock_secret
WEBHOOK_SECRET_NMI=mock_secret
WEBHOOK_SECRET_CARDPOINTE=mock_secret
