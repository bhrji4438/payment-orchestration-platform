# =============================================================================
# PAYMENT ORCHESTRATION PLATFORM — Invoice Generation Service
# =============================================================================
# Generated automatically using:
#   npm run bootstrap:env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

NODE_ENV=development
PORT=3001

# Database Connection (Prisma)
DATABASE_URL=postgresql://postgres:Password@123@localhost:5432/payment_platform?schema=public

# Kafka configuration
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true

# MinIO / S3 Object Storage API (Reserved for PDF invoice storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=false
